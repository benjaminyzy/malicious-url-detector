{
  "name": "Malicious URL Detector",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Real-time malicious URL detection powered by machine learning",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/shield.png",
      "48": "icons/shield.png",
      "128": "icons/shield.png"
    }
  },
  "icons": {
    "16": "icons/shield.png",
    "48": "icons/shield.png",
    "128": "icons/shield.png"
  }
}
